{
  "sourceLanguage": "en",
  "strings": {
    "SIMMER": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "SIMMER"
          }
        }
      }
    },
    "PRO": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "PRO"
          }
        }
      }
    },
    "Nothing on the stove": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "灶上空空"
          }
        }
      }
    },
    "Tap a preset below to start a timer.\nIt lives on your Lock Screen and\nin the Dynamic Island.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击下方预设开始计时。\n它会显示在锁屏和\n灵动岛上。"
          }
        }
      }
    },
    "Restart": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "重新开始"
          }
        }
      }
    },
    "+1 minute": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "+1 分钟"
          }
        }
      }
    },
    "Cancel": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "取消"
          }
        }
      }
    },
