    "SIMMER PRO": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "SIMMER PRO"
          }
        }
      }
    },
    "Run every burner at once — unlimited timers": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "同时运行每个灶台 — 无限计时"
          }
        }
      }
    },
    "All of them grouped in the Dynamic Island": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "全部聚合在灵动岛"
          }
        }
      }
    },
    "Save your go-to timers as presets": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "把常用计时存为预设"
          }
        }
      }
    },
    "Restart finished timers without rebuilding them": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一键重启已完成的计时"
          }
        }
      }
    },
    "Support an indie developer": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "支持独立开发者"
          }
        }
      }
    },
    "PAY ONCE. YOURS FOREVER.\nNO SUBSCRIPTION. NO ACCOUNT.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一次购买,终身可用。\n无需订阅,无需账号。"
          }
        }
      }
    },
    "UNLOCK FOR %@": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "以 %@ 解锁"
          }
        }
